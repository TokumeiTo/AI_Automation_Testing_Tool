# ====================================================================
# CACHE AND LOGS
# ====================================================================
.eslintcache
*.log
.DS_Store
Thumbs.db

# ====================================================================
# NODE / FRONTEND / TEST-RUNNER DEPENDENCIES
# ====================================================================
node_modules/
frontend/node_modules/

# 🟩 ALLOWED BROWSER STACK: 
# We leave 'frontend/ms-playwright/' completely out of the ignore patterns 
# so Git naturally enters the folder and tracks your standalone testing suite.

# 🛑 BLOCKED BUILD OUTPUTS
dist/
/frontend/dist/
/test-runner/playwright-report/
/test-runner/test-results/

# ====================================================================
# PYTHON / BACKEND ENVIRONMENTS
# ====================================================================
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.env

# ====================================================================
# LOCAL CONFIGURATION FILES
# ====================================================================
.vscode/
.idea/
*.suo    
*.ntvs*
*.njsproj
*.sln
*.swp

# ====================================================================
# AIR-GAPPED DEPLOYMENT FIREWALL LAYER
# ====================================================================

# 🛑 PREVENT CRASHES: Only block the 3 exact giant files that exceed GitHub's 100MB limit.
# This keeps your push safe while letting chrome.exe, chrome_elf.dll, etc., pass naturally.
**/chrome-win64/chrome.dll
**/chrome-headless-shell-win64/chrome-headless-shell.exe
**/firefox/xul.dll

# ⚡ CHUNK EXCEPTIONS: Force Git to track our manually split chunk files instead!
!**/*.part*
!**/*_validated
!**/*_complete