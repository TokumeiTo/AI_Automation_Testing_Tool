# Cache and logs
.eslintcache
*.log
.DS_Store
Thumbs.db

# Node / Frontend / Test-Runner dependencies
# 🟩 Commented out so Git tracks your portable dependencies and browser assets
node_modules/
# playwright-browsers/
frontend/node_modules/
# ms-playwright/
# frontend/ms-playwright/

# 🛑 KEEP BLOCKED: Only block webkit until we check its size or split it
# backend/ms-playwright/webkit-2311/

# 🟩 ALLOWED: Commented out (or deleted) so Git can see and track them!
# frontend/ms-playwright/firefox-1532/
# frontend/ms-playwright/ffmpeg-1011/
# frontend/ms-playwright/winldd-1007/
# frontend/ms-playwright/.links/

dist/
/frontend/dist/
/test-runner/playwright-report/
/test-runner/test-results/

# Python / Backend environments
# 🟩 Keep venv ignored because your new "python-portable" folder handles this now
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.env

# Local configuration files
.vscode/
.idea/
*.suo   
*.ntvs*
*.njsproj
*.sln
*.swp

# Prevent tracking the original large binary layouts
**.dll
**.exe

# ⚡ EXCEPTIONS: Force Git to track our small chunked pieces!
!**/*.part*
!**/*.exe
!**/*_validated
!**/*_complete